+// Re-adds the Rumble-specific channel-wallet + walletTypes surface to the
+// inherited (now generic) WDK wallet routes.
+const applyChannelWalletSchemas = (ctx) => {
+  // POST /api/v1/wallets: allow type 'channel' and the channelId field, and
+  // require channelId when the wallet type is 'channel'.
+  const createItems = ctx.routes.get('POST:/api/v1/wallets')?.schema?.body?.items
+  if (createItems?.properties) {
+    createItems.properties.type = { enum: CHANNEL_WALLET_ENUM }
+    createItems.properties.channelId = { type: 'string', minLength: 1, maxLength: 255 }
+    createItems.allOf = [
+      {
+        if: { required: ['type'], properties: { type: { const: 'channel' } } },
+        then: { required: ['channelId'] },
+        else: { properties: { channelId: false } }
+      },
+      ...(createItems.allOf || [])
+    ]
+  }
+
+  // Balance + transfer reads accept the walletTypes filter again.
+  for (const key of [
+    'GET:/api/v1/users/:userId/balance',
+    'GET:/api/v1/users/:userId/token-transfers',
+    'GET:/api/v1/users/:userId/spark/bitcoin/token-transfers',
+    'GET:/api/v2/users/:userId/token-transfers'
+  ]) {
+    const qs = ctx.routes.get(key)?.schema?.querystring
+    if (qs?.properties) {
+      qs.properties.walletTypes = channelWalletTypesSchema
+    }
+  }
+
+  // The cached user-balance handler must key on walletTypes (otherwise a filtered
+  // and an unfiltered balance for the same user collide in the cache) and forward
+  // it to the shard. Transfer handlers already spread req.query, so they need no
+  // override.
+  const balanceRoute = ctx.routes.get('GET:/api/v1/users/:userId/balance')
+  if (balanceRoute) {
+    balanceRoute.handler = async (req, rep) => {
+      const ckeyParts = ['/api/v1/users/:userId/balance', req.params.userId, req.query.walletTypes]
+      return send200(
+        rep,
+        await cachedRoute(ctx, ckeyParts, '/api/v1/users/:userId/balance', () => service.ork.getUserBalance(ctx, req), !req.query.cache, allPropsNonNullDeep)
+      )
+    }
+  }
+}
+
 /**
