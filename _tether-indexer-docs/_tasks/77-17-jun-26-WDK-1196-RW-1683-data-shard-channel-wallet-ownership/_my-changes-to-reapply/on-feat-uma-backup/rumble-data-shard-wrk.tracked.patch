+test('channel wallet creation hooks (Rumble-owned)', async t => {
+  const { proc } = buildProc()
+
+  // _isDuplicateWallet: a channel wallet is a duplicate of another with the same channelId
+  t.ok(proc._isDuplicateWallet({ type: 'channel', channelId: 'c1' }, { type: 'channel', channelId: 'c1' }), 'same channelId is a duplicate')
+  t.absent(proc._isDuplicateWallet({ type: 'channel', channelId: 'c1' }, { type: 'channel', channelId: 'c2' }), 'different channelId is not a duplicate')
+  t.absent(proc._isDuplicateWallet({ type: 'channel', channelId: 'c1' }, { type: 'user' }), 'channel vs user is not a duplicate')
+  t.ok(proc._isDuplicateWallet({ type: 'user' }, { type: 'user' }), 'user vs user delegates to the base rule')
+
+  // _validateNewWallet: a channel wallet must carry a channelId
+  t.is(proc._validateNewWallet({ type: 'channel' }), 'ERR_CHANNEL_ID_INVALID', 'channel without channelId is rejected')
+  t.is(proc._validateNewWallet({ type: 'channel', channelId: 'c1' }), null, 'channel with channelId is accepted')
+  t.is(proc._validateNewWallet({ type: 'user' }), null, 'user delegates to the base rule')
+
+  // _buildExtraWalletFields: channelId is the Rumble-specific persisted field
+  t.is(proc._buildExtraWalletFields({ channelId: 'c1' }).channelId, 'c1', 'channelId is persisted')
+  t.is(Object.keys(proc._buildExtraWalletFields({ type: 'user' })).length, 0, 'no channelId yields no extra fields')
+})
